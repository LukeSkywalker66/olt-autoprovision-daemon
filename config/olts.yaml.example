# =============================================================================
# OLT Auto-Provision Daemon — Multi-OLT Configuration (EXAMPLE)
# =============================================================================
# Copy this file to olts.yaml and fill in your real OLT credentials.
#   cp config/olts.yaml.example config/olts.yaml
#
# WARNING: config/olts.yaml is in .gitignore — NEVER commit real credentials.
# =============================================================================
#
# YAML-First Design:
#   - The 'defaults' section provides global fallbacks for all OLTs.
#   - Each OLT entry overrides any default with OLT-specific values.
#   - New fields added to CONFIG_SCHEMA in main.py automatically flow here.
#
# Required per OLT:  name, ssh_user, ssh_pass
# Everything else:   optional (falls back to defaults section, then to code schema)
# =============================================================================

defaults:
  # ---- SSH Connection ----
  ssh_port: 22                    # Puerto SSH de la OLT
  parser_model: "huawei_ma5800"   # Modelo de parser syslog

  # ---- Management Provisioning (gemport 2, siempre se crea) ----
  management_vlan: 150            # VLAN de gestión para WAN DHCP + TR-069
  gemport: 2                      # GEM Port para service-port de gestión
  traffic_table_up: "7"           # Traffic table inbound (índice numérico o nombre)
  traffic_table_down: "7"         # Traffic table outbound (índice numérico o nombre)
  tr069_profile_id: 1             # TR-069 server profile ID
  dhcp_priority: 2                # Prioridad 802.1p para WAN DHCP
  ip_index: 0                     # IP index para ont ipconfig

  # ---- Internet Provisioning (gemport 1, opcional) ----
  # Descomentar internet_vlan para habilitar un service-port extra de internet:
  # internet_vlan: 600            # VLAN de datos/internet
  # internet_gemport: 1           # GEM port para internet (típicamente 1)
  # internet_traffic_table_up: "7"    # Traffic table inbound para internet
  # internet_traffic_table_down: "7"  # Traffic table outbound para internet

  # ---- Operational Tuning ----
  cmd_delay: 0.4                  # Delay entre comandos SSH (segundos)
  max_retries: 10                 # Reintentos por comando ante OLT ocupada
  dedup_ttl_seconds: 300          # TTL del caché de deduplicación (5 minutos)

olts:
  # -------------------------------------------------------------------
  # Ejemplo 1: OLT básica (solo credenciales, hereda todo de defaults)
  # -------------------------------------------------------------------
  "10.11.104.2":
    name: "NODO-HORNILLOS"
    ssh_user: "CHANGE_ME"
    ssh_pass: "CHANGE_ME"

  # -------------------------------------------------------------------
  # Ejemplo 2: OLT con traffic-tables por nombre y profile-id distinto
  # -------------------------------------------------------------------
  "10.11.104.5":
    name: "Villa Dolores 2"
    ssh_user: "CHANGE_ME"
    ssh_pass: "CHANGE_ME"
    tr069_profile_id: 2
    traffic_table_up: "SMARTOLT-VOIPMNG-10M"    # Nombre en vez de índice
    traffic_table_down: "SMARTOLT-VOIPMNG-10M"

  # -------------------------------------------------------------------
  # Ejemplo 3: OLT con puerto SSH no estándar
  # -------------------------------------------------------------------
  "138.59.175.11":
    name: "OLT-San_Jose"
    ssh_user: "CHANGE_ME"
    ssh_pass: "CHANGE_ME"
    ssh_port: 1230

  # -------------------------------------------------------------------
  # Ejemplo 4: OLT con service-port de internet (gemport 1) adicional
  # -------------------------------------------------------------------
  # "10.20.30.40":
  #   name: "NODO-CON-INTERNET"
  #   ssh_user: "CHANGE_ME"
  #   ssh_pass: "CHANGE_ME"
  #   internet_vlan: 600              # Habilita service-port de internet
  #   internet_gemport: 1
  #   internet_traffic_table_up: "7"
  #   internet_traffic_table_down: "7"

  # -------------------------------------------------------------------
  # Agregar más OLTs aquí siguiendo el mismo formato.
  # La IP debe coincidir EXACTAMENTE con la IP origen de los paquetes
  # UDP que envía la OLT al exportar syslog.
  # -------------------------------------------------------------------
